{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["gitlabci", "gitlabci-include", "pep621", "dockerfile"],
  "rebaseWhen": "behind-base-branch",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchDepTypes": ["test"],
      "matchPackageNames": ["pytest", "pytest-cov", "pytest-mock", "pytest-asyncio", "pytest-freezegun", "requests-mock", "fakeredis", "freezegun", "tox", "pylint", "pylint-pydantic", "bandit"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "additionalBranchPrefix": "test-",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["patch"],
      "additionalBranchPrefix": "dev-",
      "automerge": true
    }
  ]
}
